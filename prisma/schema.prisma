generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  BAR_ADMIN
  ATTENDEE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phone        String?
  role         Role     @default(BAR_ADMIN)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  bar          Bar?     @relation("BarAdmin")
  registrations Registration[]

  @@map("users")
}

model Bar {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?
  logo         String?
  coverImage   String?  @map("cover_image")
  address      String?
  phone        String?
  socialMedia  Json?    @map("social_media")
  schedule     Json?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  adminId      String   @unique @map("admin_id")
  admin        User     @relation("BarAdmin", fields: [adminId], references: [id])

  forms        Form[]
  events       Event[]
  menuCategories MenuCategory[]
  gallery      BarGallery[]

  @@map("bars")
}

model Form {
  id        String   @id @default(uuid())
  name      String
  fields    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  barId     String   @map("bar_id")
  bar       Bar      @relation(fields: [barId], references: [id], onDelete: Cascade)

  events    Event[]

  @@map("forms")
}

enum EventType {
  SINGLE
  RECURRING
}

enum AccessType {
  FREE
  FREE_WITH_FORM
  PAID
}

model Event {
  id              String     @id @default(uuid())
  title           String
  description     String?
  image           String?
  startDate       DateTime   @map("start_date")
  endDate         DateTime?  @map("end_date")
  eventType       EventType  @default(SINGLE) @map("event_type")
  recurrenceRule  Json?      @map("recurrence_rule")
  accessType      AccessType @default(FREE) @map("access_type")
  hasAccessControl Boolean   @default(false) @map("has_access_control")
  price           Float?
  capacity        Int?
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  barId           String     @map("bar_id")
  bar             Bar        @relation(fields: [barId], references: [id], onDelete: Cascade)

  formId          String?    @map("form_id")
  form            Form?      @relation(fields: [formId], references: [id])

  registrations   Registration[]
  attendances     Attendance[]
  occurrences     EventOccurrence[]

  @@map("events")
}

model EventOccurrence {
  id        String   @id @default(uuid())
  date      DateTime
  createdAt DateTime @default(now()) @map("created_at")

  eventId   String   @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  registrations Registration[]
  attendances   Attendance[]

  @@unique([eventId, date])
  @@map("event_occurrences")
}

enum PaymentStatus {
  PENDING
  PAID
  FREE
}

model Registration {
  id            String        @id @default(uuid())
  formData      Json?         @map("form_data")
  qrToken       String        @unique @default(uuid()) @map("qr_token")
  paymentStatus PaymentStatus @default(FREE) @map("payment_status")
  createdAt     DateTime      @default(now()) @map("created_at")

  eventId       String        @map("event_id")
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  occurrenceId  String?       @map("occurrence_id")
  occurrence    EventOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  attendeeId    String?       @map("attendee_id")
  attendee      User?         @relation(fields: [attendeeId], references: [id])

  attendance    Attendance?
  payment       Payment?
  orderItems    OrderItem[]

  @@map("registrations")
}

enum CheckinMethod {
  QR
  MANUAL
}

model Attendance {
  id              String        @id @default(uuid())
  method          CheckinMethod @default(QR)
  checkedInAt     DateTime      @default(now()) @map("checked_in_at")

  registrationId  String        @unique @map("registration_id")
  registration    Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  eventId         String        @map("event_id")
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  occurrenceId    String?       @map("occurrence_id")
  occurrence      EventOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  @@map("attendances")
}

enum PaymentState {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id              String       @id @default(uuid())
  amount          Float
  state           PaymentState @default(PENDING)
  externalRef     String?      @map("external_ref")
  createdAt       DateTime     @default(now()) @map("created_at")

  registrationId  String       @unique @map("registration_id")
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model MenuCategory {
  id        String     @id @default(uuid())
  name      String
  order     Int        @default(0)
  createdAt DateTime   @default(now()) @map("created_at")

  barId     String     @map("bar_id")
  bar       Bar        @relation(fields: [barId], references: [id], onDelete: Cascade)

  items     MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  image       String?
  available   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  categoryId  String   @map("category_id")
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  orderItems  OrderItem[]

  @@map("menu_items")
}

enum MediaType {
  IMAGE
  VIDEO
}

model BarGallery {
  id        String    @id @default(uuid())
  url       String
  caption   String?
  type      MediaType @default(IMAGE)
  order     Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  barId     String    @map("bar_id")
  bar       Bar       @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@map("bar_gallery")
}

model OrderItem {
  id              String       @id @default(uuid())
  quantity        Int          @default(1)
  unitPrice       Float        @map("unit_price")
  notes           String?
  delivered       Boolean      @default(false)
  deliveredAt     DateTime?    @map("delivered_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  registrationId  String       @map("registration_id")
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  menuItemId      String       @map("menu_item_id")
  menuItem        MenuItem     @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}
